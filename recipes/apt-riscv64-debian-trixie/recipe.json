{
  "artifactId": "apt-riscv64-debian-trixie",
  "type": "debian-package-set",
  "version": "trixie-riscv64",
  "summary": "Debian trixie riscv64 apt runtime package set.",
  "debian": {
    "mirror": "https://deb.debian.org/debian",
    "suite": "trixie",
